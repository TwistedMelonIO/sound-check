# Sound Check - Environment Configuration
PROJECT_NAME=sound-check

# Web Dashboard
WEB_PORT=3000

# OSC Listen Port (receives from StreamDeck / Bitfocus Companion)
OSC_LISTEN_PORT=53538

# OSC Bridge (sends to QLab)
BRIDGE_URL=http://sound-check-bridge:3401
BRIDGE_PORT=3401
QLAB_HOST=host.docker.internal
QLAB_PORT=53000

# Audio file base path (mapped volume inside container)
TRACK_BASE_PATH=/app/qlab-audio

# Admin password for sensitive operations
ADMIN_PASSWORD=8888
